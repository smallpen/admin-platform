generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  username     String     @unique
  email        String     @unique
  passwordHash String     @map("password_hash")
  displayName  String     @map("display_name")
  avatar       String?
  status       String     @default("ACTIVE")
  lastLoginAt  DateTime?  @map("last_login_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  userRoles            UserRole[]
  refreshTokens        RefreshToken[]
  activityLogs         ActivityLog[]
  announcementsCreated Announcement[]         @relation("AnnouncementCreator")
  announcementReads    UserAnnouncementRead[]

  @@map("users")
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  displayName String   @map("display_name")
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  group       String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  rolePermissions RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model RefreshToken {
  id        String    @id @default(cuid())
  token     String    @unique @db.VarChar(512)
  userId    String    @map("user_id")
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// UserStatus values: "ACTIVE" | "INACTIVE" | "LOCKED"

model MaintenanceStatus {
  id          Int       @id @default(1)
  isActive    Boolean   @default(false) @map("is_active")
  activatedAt DateTime? @map("activated_at")
  activatedBy String?   @map("activated_by")
  message     String?
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("maintenance_status")
}

model MaintenanceSchedule {
  id             String    @id @default(cuid())
  name           String
  cronExpression String    @map("cron_expression")
  duration       Int       @default(60)
  isEnabled      Boolean   @default(true) @map("is_enabled")
  lastRunAt      DateTime? @map("last_run_at")
  nextRunAt      DateTime? @map("next_run_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("maintenance_schedules")
}

model ProxyApi {
  id              String   @id @default(cuid())
  name            String
  path            String   @unique
  method          String   @default("POST")
  description     String?
  storedProcedure String   @map("stored_procedure")
  paramMappings   Json     @map("param_mappings")
  requireAuth     Boolean  @default(true) @map("require_auth")
  authType        String   @default("JWT") @map("auth_type")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  callLogs ApiCallLog[]

  @@map("proxy_apis")
}

model ApiKey {
  id          String    @id @default(cuid())
  name        String
  keyHash     String    @unique @map("key_hash")
  keyPrefix   String    @map("key_prefix")
  allowedApis Json      @map("allowed_apis")
  isActive    Boolean   @default(true) @map("is_active")
  expiresAt   DateTime? @map("expires_at")
  lastUsedAt  DateTime? @map("last_used_at")
  createdBy   String    @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  callLogs ApiCallLog[]

  @@map("api_keys")
}

model ApiCallLog {
  id           String   @id @default(cuid())
  apiId        String   @map("api_id")
  apiKeyId     String?  @map("api_key_id")
  callerIp     String   @map("caller_ip")
  requestBody  Json?    @map("request_body")
  responseCode Int      @map("response_code")
  durationMs   Int      @map("duration_ms")
  errorMsg     String?  @map("error_msg") @db.Text
  calledAt     DateTime @default(now()) @map("called_at")

  proxyApi ProxyApi @relation(fields: [apiId], references: [id], onDelete: Cascade)
  apiKey   ApiKey?  @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)

  @@index([apiId])
  @@index([calledAt])
  @@map("api_call_logs")
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  action     String
  module     String
  targetId   String?  @map("target_id")
  targetName String?  @map("target_name") @db.VarChar(500)
  before     Json?
  after      Json?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent") @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([module])
  @@index([action])
  @@index([createdAt])
  @@map("activity_logs")
}

model Announcement {
  id        String    @id @default(cuid())
  title     String
  content   String    @db.Text
  type      String    @default("INFO")
  status    String    @default("DRAFT")
  startAt   DateTime? @map("start_at")
  endAt     DateTime? @map("end_at")
  createdBy String    @map("created_by")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  creator User                   @relation("AnnouncementCreator", fields: [createdBy], references: [id])
  reads   UserAnnouncementRead[]

  @@map("announcements")
}

model UserAnnouncementRead {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  announcementId String   @map("announcement_id")
  readAt         DateTime @default(now()) @map("read_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@unique([userId, announcementId])
  @@map("user_announcement_reads")
}

model ScheduledTask {
  id             String    @id @default(cuid())
  name           String
  taskType       String    @map("task_type")
  cronExpression String    @map("cron_expression")
  isEnabled      Boolean   @default(false) @map("is_enabled")
  lastRunAt      DateTime? @map("last_run_at")
  lastStatus     String?   @map("last_status")
  lastMessage    String?   @map("last_message") @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("scheduled_tasks")
}

model Advertisement {
  id        String   @id @default(cuid())
  title     String
  imageData Bytes    @map("image_data") @db.LongBlob
  mimeType  String   @map("mime_type")
  imageName String   @map("image_name")
  linkUrl   String?  @map("link_url")
  duration  Int      @default(5)
  isActive  Boolean  @default(true) @map("is_active")
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("advertisements")
}
