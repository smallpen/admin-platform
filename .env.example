# ── 後端環境變數 ──────────────────────────────────────────────────────────────

# 資料庫連線
# 本機開發: file:./prisma/dev.db
# Docker 部署: file:/data/app.db（由 docker-compose 自動設定）
DATABASE_URL=file:./prisma/dev.db

# JWT 密鑰（生產環境請使用 64 字元以上的隨機字串）
# 產生指令: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your-access-secret-min-32-chars-change-this
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-change-this

# JWT 過期時間
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# 後端伺服器設定
BACKEND_PORT=3001
BACKEND_HOST=0.0.0.0

# CORS：允許的前端來源
CORS_ORIGIN=http://localhost:5173

# ── 前端環境變數 ──────────────────────────────────────────────────────────────

# 本機開發時指定後端完整 URL
VITE_API_BASE_URL=http://localhost:3001/api/v1
# Docker 部署時使用 /api/v1（相對路徑，由 Nginx proxy 轉發）
# VITE_API_BASE_URL=/api/v1

# ── Docker 部署專用 ───────────────────────────────────────────────────────────

# 前端對外 HTTP port（預設 80）
HTTP_PORT=80

# 部署後請將 CORS_ORIGIN 改為實際 domain
# CORS_ORIGIN=https://your-domain.com
